OPENAI_API_KEY=
DATABASE_URL=postgresql://admin:admin@postgres:5432/vector_db

# Azure
LLM_PROVIDER=azure
LLM_BASE_URL=https://your-resource.openai.azure.com
LLM_API_KEY=your-azure-key
LLM_CHAT_MODEL=gpt-4o
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_API_VERSION=2024-02-01

# Ollama
LLM_PROVIDER=ollama
LLM_BASE_URL=http://host.docker.internal:11434
LLM_CHAT_MODEL=llama3.2
LLM_EMBEDDING_MODEL=nomic-embed-text

# LM Studio
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://host.docker.internal:1234/v1
LLM_CHAT_MODEL=unsloth-qwen3-30b-a3b-instruct-2507-mlx
LLM_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
LLM_EMBEDDING_DIMENSIONS=768

# OpenAI
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_CHAT_MODEL=gpt-4o
LLM_EMBEDDING_MODEL=text-embedding-3-small